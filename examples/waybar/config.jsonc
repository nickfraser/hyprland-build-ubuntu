{
  "layer": "top",
  "position": "top",
  "height": 32,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["clock"],
  "hyprland/workspaces": {
    "all-outputs": true,
    "format": "{name}"
  },
  "hyprland/window": {
    "max-length": 80,
    "separate-outputs": true
  },
  "clock": {
    "format": "{:%Y-%m-%d %H:%M}"
  }
}
